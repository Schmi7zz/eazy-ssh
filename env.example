# Telegram Bot Token from @BotFather
BOT_TOKEN=

# Full HTTPS URL to your Mini App frontend
WEBAPP_URL=https://ssh-terminal.yourdomain.com

# Your Telegram user ID (from @userinfobot) — used for /stats, /broadcast
ADMIN_ID=

# ─── Optional: Channel Membership Gate ───
# If set, users must be members of this channel to use the Chat Terminal.
# The bot must be an admin of the channel (or member with access) for get_chat_member to work.
# Leave empty to disable this feature.
REQUIRED_CHANNEL=
REQUIRED_CHANNEL_URL=

# ─── Backend (Go WebSocket proxy) ───
PORT=8080
ALLOWED_ORIGIN=
